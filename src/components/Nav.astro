---
import { Icon } from "astro-icon/components";

const links = [
  { href: "/#about", label: "About" },
  { href: "/#skills", label: "Skills" },
  { href: "/#projects", label: "Projects" },
  { href: "https://blog.dmartel.dev", label: "Blog", external: true },
];
---

<header
  class="sticky top-0 z-50 border-b border-white/10 bg-bg/80 backdrop-blur supports-[backdrop-filter]:bg-bg/60"
>
  <nav
    class="mx-auto flex max-w-4xl flex-wrap items-center justify-between gap-x-6 gap-y-2 px-6 py-4"
    aria-label="Primary"
  >
    <a
      href="/#top"
      class="font-mono text-sm font-medium text-text hover:text-accent transition-colors"
    >
      <span class="text-accent">&gt;</span> dmartel
    </a>

    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-text-muted hover:text-accent transition-colors"
            {...(link.external
              ? { target: "_blank", rel: "noopener noreferrer" }
              : {})}
          >
            {link.label}
            {link.external && (
              <Icon
                name="lucide:arrow-up-right"
                class="inline size-3.5 align-[-1px]"
                aria-hidden="true"
              />
            )}
          </a>
        ))
      }

      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle color theme"
        class="flex size-8 items-center justify-center rounded-md border border-white/10 text-text-muted transition-colors hover:border-accent hover:text-accent"
      >
        <Icon
          name="lucide:sun"
          class="size-4 hidden [html[data-theme='light']_&]:block"
          aria-hidden="true"
        />
        <Icon
          name="lucide:moon"
          class="size-4 block [html[data-theme='light']_&]:hidden"
          aria-hidden="true"
        />
      </button>
    </div>
  </nav>
</header>

<script>
  function initThemeToggle() {
    const btn = document.getElementById("theme-toggle");
    if (!btn || btn.dataset.bound) return;
    btn.dataset.bound = "true";
    btn.addEventListener("click", () => {
      const isLight =
        document.documentElement.getAttribute("data-theme") === "light";
      const next = isLight ? "dark" : "light";
      if (next === "light") {
        document.documentElement.setAttribute("data-theme", "light");
      } else {
        document.documentElement.removeAttribute("data-theme");
      }
      localStorage.setItem("theme", next);
    });
  }
  document.addEventListener("astro:page-load", initThemeToggle);
</script>
